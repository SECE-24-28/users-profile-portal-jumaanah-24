generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Student {
  id          String   @id @default(uuid())
  name        String
  age         Int
  department  String
  email       String   @unique
  image       String?
  createdAt   DateTime @default(now())
}